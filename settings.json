{
    // The Twerkflow environment context.
    "context": "twerkflow_dev",

    // Interval in seconds for polling GitHub issues.
    "poll_interval_seconds": 30,

    "drivers": {
        "task_service": {
            "type": "github_issues",
            "params": {
                "repo_name": "gvanderest/twerkflow",
                "label_to_search": "twerkflow"
            }
        },
        "doc_service": "github_wiki",
        "pr_service": "github_pr"
    }
}
